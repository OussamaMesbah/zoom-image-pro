{
    "manifest_version": 3,
    "name": "Zoom Image Pro",
    "version": "1.0.0",
    "description": "Seamlessly zoom, pan, rotate, flip, and download any image on any webpage. Supports scroll zoom, trackpad pinch, and gallery navigation.",

    "homepage_url": "https://buymeacoffee.com/omesbahf",
    "permissions": [
        "activeTab",
        "storage",
        "tabs"
    ],
    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon-16.png",
            "48": "icons/icon-48.png",
            "128": "icons/icon-128.png"
        }
    },
    "options_page": "options.html",
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}